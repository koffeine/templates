{
	"exclude": [
		"dist"
	],
	"compilerOptions": {
		// Type Checking
		"strict": true,

		// Modules
		"module": "esnext",
		"moduleResolution": "bundler",

		// Emit
		"noEmit": true,

		// JavaScript Support
		"allowJs": true,
		"checkJs": true,

		// Language and Environment
		"target": "esnext",

		// Completeness
		"skipLibCheck": true
	}
}
