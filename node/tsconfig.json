{
	"compilerOptions": {
		// Type Checking
		"strict": true,

		// Modules
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"noUncheckedSideEffectImports": true,
		"types": [],

		// Emit
		"noEmit": true,

		// JavaScript Support
		"allowJs": true,
		"checkJs": true,

		// Language and Environment
		"target": "esnext",

		// Completeness
		"skipLibCheck": true
	}
}
